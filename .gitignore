# .gitignore — Place in project root
# ─── Secrets (CRITICAL — never commit these) ────────────────────
.env
.env.local
.env.production
.env.development
.env*.local

# ─── Build output ────────────────────────────────────────────────
.next/
out/
build/

# ─── Dependencies ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Backup / temporary files ────────────────────────────────────
*.bak
*.backup
*.orig
*.tmp
*.swp
.DS_Store
Thumbs.db

# ─── Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
