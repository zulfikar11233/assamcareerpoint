# .env.local — TEMPLATE FILE
# ─────────────────────────────────────────────────────────────────
# IMPORTANT: Rename this file to .env.local before use
# NEVER commit this file to Git — add .env.local to .gitignore
# On Hostinger: set these as Environment Variables in hPanel (not as a file)
# ─────────────────────────────────────────────────────────────────

# ── Your site URL (no trailing slash) ────────────────────────────
NEXTAUTH_URL=https://www.assamcareerpoint-info.com

# ── Secret key for JWT signing (REQUIRED — must be random & long) ─
# Generate with: openssl rand -base64 32
# Example output: K9mPxvL2nQwR7tY3hJ8sA5dF1gE6bI0c=
NEXTAUTH_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32

# ── Admin login credentials ───────────────────────────────────────
# Choose any username (not "admin" — too obvious)
ADMIN_USERNAME=your_chosen_username

# ── Bcrypt password hash (NEVER store plain password) ─────────────
# Step 1: Choose a strong password (12+ chars, mixed case, numbers, symbols)
#         Example strong password: Assam@2026#Portal!
#
# Step 2: Generate hash — run this command in your terminal:
#         node -e "require('bcryptjs').hash('YOUR_PASSWORD_HERE', 12, (e,h) => console.log(h))"
#
# Step 3: Copy the output (starts with $2b$12$...) and paste below
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_YOUR_BCRYPT_HASH_HERE

# ─────────────────────────────────────────────────────────────────
# HOW TO INSTALL REQUIRED PACKAGES:
# npm install bcryptjs next-auth
# npm install --save-dev @types/bcryptjs
# ─────────────────────────────────────────────────────────────────
